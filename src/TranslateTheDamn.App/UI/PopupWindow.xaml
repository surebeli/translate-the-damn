<Window x:Class="TranslateTheDamn.App.UI.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowActivated="False" Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        SizeToContent="Height" Width="440"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        MouseEnter="Root_MouseEnter" MouseLeave="Root_MouseLeave">
    <Border x:Name="Root" CornerRadius="12" Background="#E61C1C1C" Padding="16" Margin="10"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.55" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                <TextBlock x:Name="HeaderText" Text="翻译" Foreground="#8FE3C0" FontSize="12" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <TextBlock x:Name="StatusText" Text="" Foreground="#88AAAAAA" FontSize="11" DockPanel.Dock="Right"/>
            </DockPanel>

            <TextBlock x:Name="SourceText" Foreground="#90AAAAAA" FontSize="12" TextWrapping="Wrap"
                       MaxHeight="84" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
            <Border Height="1" Background="#22FFFFFF" Margin="0,0,0,10"/>
            <ScrollViewer x:Name="TranslationScroll" MaxHeight="320"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="TranslationScroll_PreviewMouseWheel">
                <TextBlock x:Name="TranslationText" Foreground="#F2F2F2" FontSize="15" TextWrapping="Wrap"
                           LineHeight="22" Margin="0,0,8,0"/>
            </ScrollViewer>

            <DockPanel LastChildFill="False" Margin="0,12,0,0">
                <Button x:Name="CopyButton" Content="复制译文" DockPanel.Dock="Right" Padding="12,5"
                        Foreground="White" Background="#2EA043" BorderThickness="0" Cursor="Hand"
                        Click="CopyButton_Click"/>
            </DockPanel>
        </StackPanel>
    </Border>
</Window>
