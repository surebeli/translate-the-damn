<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\TranslateTheDamn.Core\TranslateTheDamn.Core.csproj" />
  </ItemGroup>

  <!-- i18n: bundle the shared locale catalogs beside the exe so StringsLoader finds strings/<locale>.json
       (repo-root strings/*.json -> output strings/). Mirrors the macOS build-app.sh locale copy. -->
  <ItemGroup>
    <Content Include="..\..\..\..\strings\*.json" Link="strings\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>TranslateTheDamn.App</RootNamespace>
    <AssemblyName>TranslateTheDamn</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>app.ico</ApplicationIcon>

    <!-- SINGLE source of truth for the Windows version. FileVersion / AssemblyVersion /
         InformationalVersion all DERIVE from <Version> by MSBuild default (no prerelease label here),
         so only this one line moves on a bump. Read at runtime from the assembly for the settings caption. -->
    <Version>0.4.0</Version>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Product>translate-the-damn</Product>
    <AssemblyTitle>translate-the-damn — 全局一键翻译</AssemblyTitle>
    <Description>基于 LLM CLI / API 的全局一键翻译热键工具</Description>
    <Company>litianyi</Company>
    <Copyright>Copyright © 2026 litianyi</Copyright>

    <!-- WPF owns DPI via PerMonitorV2 in app.manifest; silence the WinForms-only DPI analyzer. -->
    <NoWarn>$(NoWarn);WFO0003</NoWarn>
  </PropertyGroup>

</Project>
