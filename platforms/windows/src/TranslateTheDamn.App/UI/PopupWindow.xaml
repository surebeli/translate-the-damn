<Window x:Class="TranslateTheDamn.App.UI.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowActivated="False" Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        Width="440" Height="360"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        MouseEnter="Root_MouseEnter" MouseLeave="Root_MouseLeave">
    <!-- Button hover/press/disabled visuals (incl. the dimmed ◀/▶ boundary arrows) come from the
         app-wide dark Button template in UI/Theme.xaml, merged via App.xaml. -->
    <!-- Exactly two fixed sizes (spec §8): normal 440x360, large = 2x width x 1.5x height. The window
         snaps to one of the two in code (ApplySize); the source is capped at ~2 lines and the
         translation scrolls inside, so different content lengths never produce a third size. -->
    <!-- Single rounded border. The card fills the whole window (Margin=0), so the acrylic frost shows
         only THROUGH the translucent card — there is no transparent margin for the acrylic to fill, hence
         no separate frosted ring / second rounded edge. CornerRadius matches the DWM window rounding
         (DWMWCP_ROUND) so the card edge and the window edge coincide. Card is ~50% opaque so the frost
         reads through it; the acrylic tint supplies the dark base for text readability.
         (No WPF drop shadow here: it would require a transparent margin, which is exactly what produced
         the second edge the popup used to show.) -->
    <Border x:Name="Root" CornerRadius="8" Background="#801C1C1C" Padding="16" Margin="0"
            BorderBrush="#40FFFFFF" BorderThickness="1"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- header -->
                <RowDefinition Height="Auto"/>   <!-- source (≤ 2 lines) -->
                <RowDefinition Height="Auto"/>   <!-- divider -->
                <RowDefinition Height="*"/>      <!-- translation fills the fixed window, scrolls -->
                <RowDefinition Height="Auto"/>   <!-- nav + actions -->
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,8">
                <TextBlock x:Name="HeaderText" Text="翻译" Foreground="#8FE3C0" FontSize="12" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                <TextBlock x:Name="StatusText" Text="" Foreground="#B8B8B8" FontSize="11" DockPanel.Dock="Right"/>
            </DockPanel>

            <!-- italic + 2-line cap mirrors the macOS DS source signature; never grows the window -->
            <TextBlock x:Name="SourceText" Grid.Row="1" Foreground="#B0B0B0" FontSize="12" FontStyle="Italic"
                       TextWrapping="Wrap" MaxHeight="36" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>

            <Border x:Name="SourceDivider" Grid.Row="2" Height="1" Background="#22FFFFFF" Margin="0,0,0,10"/>

            <ScrollViewer x:Name="TranslationScroll" Grid.Row="3"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="TranslationScroll_PreviewMouseWheel">
                <TextBlock x:Name="TranslationText" Foreground="#F2F2F2" FontSize="15" TextWrapping="Wrap"
                           LineHeight="22" Margin="0,0,8,0"/>
            </ScrollViewer>

            <DockPanel Grid.Row="4" LastChildFill="False" Margin="0,12,0,0">
                <!-- History nav: ◀ older · i / n · ▶ newer. Hidden unless >1 cached entry. -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="PrevButton" Content="◀" Padding="9,3" Visibility="Collapsed"
                            Foreground="#EDEDED" Background="#3A3A3A" BorderThickness="0" Cursor="Hand"
                            ToolTip="较早" Click="PrevButton_Click"/>
                    <TextBlock x:Name="HistoryIndicator" Text="" Visibility="Collapsed" Margin="8,0"
                               VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="11"/>
                    <Button x:Name="NextButton" Content="▶" Padding="9,3" Visibility="Collapsed"
                            Foreground="#EDEDED" Background="#3A3A3A" BorderThickness="0" Cursor="Hand"
                            ToolTip="较新" Click="NextButton_Click"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="CloseButton" Content="关闭" Padding="12,5"
                            Foreground="#EDEDED" Background="#3A3A3A" BorderThickness="0" Cursor="Hand"
                            Click="CloseButton_Click"/>
                    <Button x:Name="CopyButton" Content="复制译文" Padding="12,5" Margin="8,0,0,0"
                            Foreground="White" Background="#2EA043" BorderThickness="0" Cursor="Hand"
                            Click="CopyButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
