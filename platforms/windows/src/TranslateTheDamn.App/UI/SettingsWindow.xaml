<Window x:Class="TranslateTheDamn.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="translate-the-damn · 设置" Height="640" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#1B1B1B" Foreground="#EDEDED"
        FontFamily="Segoe UI, Microsoft YaHei UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EDEDED"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8FE3C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EDEDED"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="18">
            <StackPanel>

                <!-- 监听与触发 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="监听与触发" Style="{StaticResource GroupHeader}"/>
                        <CheckBox x:Name="ChkListen" Content="启用剪贴板监听(复制即翻译)" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="翻译热键"/>
                            <TextBox x:Name="TxtHotkey" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="LblHotkeyStatus" Style="{StaticResource Hint}" Text=""/>
                        <TextBlock Style="{StaticResource Hint}" Text="例:Ctrl+Alt+T。按下热键时翻译当前剪贴板内容。注册失败说明热键被占用。"/>
                    </StackPanel>
                </Border>

                <!-- 翻译后端 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="翻译后端" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="后端"/>
                            <ComboBox x:Name="CmbBackend" Grid.Column="1" Height="28"/>
                        </Grid>
                        <TextBlock x:Name="LblAuth" Style="{StaticResource Hint}" Text=""/>

                        <Grid x:Name="RowModel" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="模型"/>
                            <ComboBox x:Name="CmbModel" Grid.Column="1" Height="28" IsEditable="True"/>
                        </Grid>

                        <Grid x:Name="RowEndpoint" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Endpoint"/>
                            <TextBox x:Name="TxtEndpoint" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowApiKey" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API Key"/>
                            <PasswordBox x:Name="TxtApiKey" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowTarget" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="目标语言"/>
                            <TextBox x:Name="TxtTarget" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowReasoning" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="推理强度"/>
                            <TextBox x:Name="TxtReasoning" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowFallback" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="回退命令"/>
                            <TextBox x:Name="TxtFallback" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowTimeout" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="超时(秒)"/>
                            <TextBox x:Name="TxtTimeout" Grid.Column="1" Height="28" Width="80" HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 浮窗展示 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="浮窗展示" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="视觉风格"/>
                            <ComboBox x:Name="CmbStyle" Grid.Column="1" Height="28" Width="200" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="自动消失"/>
                            <Slider x:Name="SldDismiss" Grid.Column="1" Minimum="2" Maximum="30" TickFrequency="1"
                                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblDismiss" Grid.Column="2" Width="46" Text="6 s" TextAlignment="Right"/>
                        </Grid>
                        <CheckBox x:Name="ChkHover" Content="鼠标悬停时保持不消失" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 通用 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="通用" Style="{StaticResource GroupHeader}"/>
                        <CheckBox x:Name="ChkStartup" Content="开机自启"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="配置保存在 %USERPROFILE%\.translatethedamn\config.json,API Key 仅保存在本机。"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="#222222" Padding="18,12">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="LblSaveStatus" DockPanel.Dock="Left" Foreground="#8FE3C0" Text="" VerticalAlignment="Center"/>
                <Button x:Name="BtnSave" Content="保存" DockPanel.Dock="Right" Width="92" Height="32"
                        Background="#2EA043" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
                <Button x:Name="BtnClose" Content="关闭" DockPanel.Dock="Right" Width="80" Height="32" Margin="0,0,10,0"
                        Click="BtnClose_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
