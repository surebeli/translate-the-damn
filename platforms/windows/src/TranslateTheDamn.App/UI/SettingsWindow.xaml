<Window x:Class="TranslateTheDamn.App.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="translate-the-damn · 设置" Height="640" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#1B1B1B" Foreground="#EDEDED"
        FontFamily="Segoe UI, Microsoft YaHei UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EDEDED"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8FE3C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EDEDED"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9A9A9A"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <!-- Button hover/press/disabled visuals come from the app-wide dark Button template in
             UI/Theme.xaml (merged via App.xaml), so the default Aero2 light-blue hover / pale disabled
             fill never appears here. -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="18">
            <StackPanel>

                <!-- 监听与触发 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="LblGroupTrigger" Text="监听与触发" Style="{StaticResource GroupHeader}"/>
                        <CheckBox x:Name="ChkListen" Content="启用剪贴板监听(复制即翻译)" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblHotkey" Grid.Column="0" Text="翻译热键"/>
                            <TextBox x:Name="TxtHotkey" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="LblHotkeyStatus" Style="{StaticResource Hint}" Margin="0,8,0,2" Text=""/>
                        <!-- Example text is set in code from HotkeyConfig.DefaultTranslate so it can't drift
                             from the actual default. The "occupied" warning lives only on the live status
                             line above (LblHotkeyStatus) — not duplicated here. -->
                        <TextBlock x:Name="LblHotkeyExample" Style="{StaticResource Hint}" Text=""/>
                    </StackPanel>
                </Border>

                <!-- 翻译 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="LblGroupTranslate" Text="翻译" Style="{StaticResource GroupHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblTarget" Grid.Column="0" Text="目标语言"/>
                            <ComboBox x:Name="CmbTargetLang" Grid.Column="1" Height="28" IsEditable="True"/>
                        </Grid>
                        <TextBlock x:Name="LblTargetHint" Style="{StaticResource Hint}" Text="统一目标语言:对所有后端生效(CLI/LLM 经提示词 {target} 注入;google/doubao 自动转换为对应的语言代码)。"/>
                    </StackPanel>
                </Border>

                <!-- 翻译后端 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="LblGroupBackend" Text="翻译后端" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblBackend" Grid.Column="0" Text="后端"/>
                            <ComboBox x:Name="CmbBackend" Grid.Column="1" Height="28"/>
                        </Grid>
                        <TextBlock x:Name="LblAuth" Style="{StaticResource Hint}" Text=""/>

                        <Grid x:Name="RowModel" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblModel" Grid.Column="0" Text="模型"/>
                            <ComboBox x:Name="CmbModel" Grid.Column="1" Height="28" IsEditable="True" DropDownOpened="CmbModel_DropDownOpened"/>
                        </Grid>

                        <Grid x:Name="RowEndpoint" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Endpoint"/>
                            <TextBox x:Name="TxtEndpoint" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowApiKey" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="API Key"/>
                            <PasswordBox x:Name="TxtApiKey" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowProtocol" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblProtocol" Grid.Column="0" Text="接口协议"/>
                            <ComboBox x:Name="CmbProtocol" Grid.Column="1" Height="28" Width="220" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid x:Name="RowReasoning" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblReasoning" Grid.Column="0" Text="推理强度"/>
                            <ComboBox x:Name="CmbReasoning" Grid.Column="1" Height="28" IsEditable="True" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowFallback" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblFallback" Grid.Column="0" Text="回退命令"/>
                            <TextBox x:Name="TxtFallback" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>
                        </Grid>

                        <Grid x:Name="RowTimeout" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblTimeout" Grid.Column="0" Text="超时(秒)"/>
                            <TextBox x:Name="TxtTimeout" Grid.Column="1" Height="28" Width="80" HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                        </Grid>

                        <!-- 诊断(model doctor): 连通性/认证 + 模型来源 + effort 档位;深度检测发一次联网探测 -->
                        <Grid x:Name="RowDoctor" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblDoctor" Grid.Column="0" Text="诊断"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="BtnDoctor" Content="诊断后端" Padding="12,5"
                                        Foreground="White" Background="#2EA043" BorderThickness="0" Cursor="Hand"
                                        Click="BtnDoctor_Click"/>
                                <CheckBox x:Name="ChkDeep" Content="深度检测(联网,可能计费)" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <TextBox x:Name="TxtDoctorResult" Margin="0,8,0,0" Height="120" IsReadOnly="True"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                 Background="#1E1E1E" Foreground="#CFCFCF" BorderBrush="#33FFFFFF"
                                 FontFamily="Consolas, Cascadia Mono" FontSize="12" Visibility="Collapsed"/>

                        <!-- Provider 管理(放在「翻译后端」模块末尾):新增 / 删除自定义 API provider,
                             以及从本机检测并导入已有密钥。 -->
                        <Border Height="1" Background="#22FFFFFF" Margin="0,14,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="BtnAddProvider" Content="+ 新增 API" Padding="10,4" Cursor="Hand"
                                    Background="#2A2A2A" Foreground="#EDEDED" BorderBrush="#44FFFFFF" BorderThickness="1"
                                    Click="BtnAddProvider_Click"/>
                            <Button x:Name="BtnDeleteProvider" Content="删除" Padding="10,4" Margin="8,0,0,0" Cursor="Hand"
                                    Background="#2A2A2A" Foreground="#FFB4A9" BorderBrush="#44FFFFFF" BorderThickness="1"
                                    Click="BtnDeleteProvider_Click"/>
                        </StackPanel>
                        <Button x:Name="BtnDetectKeys" Content="🔍 从本机检测并导入已有密钥" HorizontalAlignment="Left" Margin="0,8,0,0"
                                Padding="10,4" Cursor="Hand" Background="#2A2A2A" Foreground="#8FE3C0" BorderBrush="#44FFFFFF"
                                BorderThickness="1" Click="BtnDetectKeys_Click"/>
                    </StackPanel>
                </Border>

                <!-- 浮窗展示 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="LblGroupPopup" Text="浮窗展示" Style="{StaticResource GroupHeader}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblStyle" Grid.Column="0" Text="视觉风格"/>
                            <ComboBox x:Name="CmbStyle" Grid.Column="1" Height="28" Width="200" HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblAutoDismiss" Grid.Column="0" Text="自动消失"/>
                            <Slider x:Name="SldDismiss" Grid.Column="1" Minimum="2" Maximum="30" TickFrequency="1"
                                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblDismiss" Grid.Column="2" Width="46" Text="6 s" TextAlignment="Right"/>
                        </Grid>
                        <CheckBox x:Name="ChkHover" Content="鼠标悬停时保持不消失" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 通用 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="LblGroupGeneral" Text="通用" Style="{StaticResource GroupHeader}"/>

                        <!-- 界面语言(显示语言)— 应用 UI 的语言,与"翻译目标语言"相互独立;"跟随系统"时按系统语言解析。
                             放在「通用」组(与 macOS generalSection 对齐)。 -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblUiLang" Grid.Column="0" Text="界面语言"/>
                            <ComboBox x:Name="CmbUiLang" Grid.Column="1" Height="28" Width="220" HorizontalAlignment="Left"/>
                        </Grid>

                        <CheckBox x:Name="ChkStartup" Content="开机自启" Margin="0,8,0,0"/>
                        <TextBlock x:Name="LblConfigHint" Style="{StaticResource Hint}"
                                   Text="配置保存在 %USERPROFILE%\.translatethedamn\config.json,API Key 仅保存在本机。"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="#222222" Padding="18,12">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="LblSaveStatus" DockPanel.Dock="Left" Foreground="#8FE3C0" Text="" VerticalAlignment="Center"/>
                <Button x:Name="BtnSave" Content="保存" DockPanel.Dock="Right" Width="92" Height="32"
                        Background="#2EA043" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click"/>
                <Button x:Name="BtnClose" Content="关闭" DockPanel.Dock="Right" Width="80" Height="32" Margin="0,0,10,0"
                        Click="BtnClose_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
