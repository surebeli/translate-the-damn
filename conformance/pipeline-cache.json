{
  "fn": "TranslationPipeline.cache",
  "doc": "Stateful: replay each scenario's steps through a FRESH pipeline + a fake translator that records call-count. expectModelCall=true ⇒ cache miss (model invoked); false ⇒ served from the recent-translation cache. Cache = up to 5 entries in most-recently-used order; key = text + backend + model; only successful results cached. A HIT promotes its entry to most-recent (refreshes recency); a MISS inserts at the front and, when size exceeds 5, evicts the least-recently-used entry.",
  "scenarios": [
    {
      "name": "same text+model hits; model/text change forces re-translate",
      "backend": "fake",
      "steps": [
        { "text": "same", "model": "m1", "expectModelCall": true },
        { "text": "same", "model": "m1", "expectModelCall": false },
        { "text": "same", "model": "m2", "expectModelCall": true },
        { "text": "other", "model": "m2", "expectModelCall": true },
        { "text": "other", "model": "m2", "expectModelCall": false }
      ]
    },
    {
      "name": "capacity 5: five distinct cached; sixth distinct evicts the least-recently-used (t1)",
      "backend": "fake",
      "steps": [
        { "text": "t1", "model": "m1", "expectModelCall": true },
        { "text": "t2", "model": "m1", "expectModelCall": true },
        { "text": "t3", "model": "m1", "expectModelCall": true },
        { "text": "t4", "model": "m1", "expectModelCall": true },
        { "text": "t5", "model": "m1", "expectModelCall": true },
        { "text": "t6", "model": "m1", "expectModelCall": true },
        { "text": "t2", "model": "m1", "expectModelCall": false },
        { "text": "t3", "model": "m1", "expectModelCall": false },
        { "text": "t4", "model": "m1", "expectModelCall": false },
        { "text": "t5", "model": "m1", "expectModelCall": false },
        { "text": "t6", "model": "m1", "expectModelCall": false },
        { "text": "t1", "model": "m1", "expectModelCall": true }
      ]
    },
    {
      "name": "access refreshes recency: a re-queried entry survives a later eviction",
      "backend": "fake",
      "steps": [
        { "text": "t1", "model": "m1", "expectModelCall": true },
        { "text": "t2", "model": "m1", "expectModelCall": true },
        { "text": "t3", "model": "m1", "expectModelCall": true },
        { "text": "t4", "model": "m1", "expectModelCall": true },
        { "text": "t5", "model": "m1", "expectModelCall": true },
        { "text": "t1", "model": "m1", "expectModelCall": false },
        { "text": "t6", "model": "m1", "expectModelCall": true },
        { "text": "t1", "model": "m1", "expectModelCall": false },
        { "text": "t2", "model": "m1", "expectModelCall": true }
      ]
    }
  ]
}
