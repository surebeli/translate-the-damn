{
  "fn": "credential.classify",
  "doc": "The static-key/OAuth import boundary (security contract). Classify(source, baseUrl, key) imports a user-owned STATIC key as an openai/anthropic http backend, or SKIPs OAuth tokens (JWT/refresh), subscription hosts (Anthropic/Google/GitHub-Copilot), and empties. Keys here are FAKE fixtures. Pinned on every platform.",
  "cases": [
    { "name": "deepseek static key -> import openai", "baseUrl": "https://api.deepseek.com/v1", "key": "sk-testdeepseek0001", "expect": { "import": true, "provider": "DeepSeek", "protocol": "openai", "suggestedId": "deepseek" } },
    { "name": "kimi coding -> import anthropic", "baseUrl": "https://api.kimi.com/coding/v1", "key": "sk-kimi-static0001", "expect": { "import": true, "provider": "Kimi Code", "protocol": "anthropic", "suggestedId": "kimi-code" } },
    { "name": "tokbox relay -> import openai", "baseUrl": "https://tokbox-api.netease.im/v1", "key": "sk-tokboxstatic01", "expect": { "import": true, "provider": "tokenbox", "protocol": "openai" } },
    { "name": "mimo token-plan -> import openai", "baseUrl": "https://token-plan-cn.xiaomimimo.com/v1", "key": "tp-staticmimo001", "expect": { "import": true, "protocol": "openai" } },
    { "name": "anthropic subscription host -> SKIP (ToS)", "baseUrl": "https://api.anthropic.com", "key": "sk-ant-static0001", "expect": { "import": false } },
    { "name": "gemini host -> SKIP (ToS/ban)", "baseUrl": "https://generativelanguage.googleapis.com", "key": "AIzaStatic0001", "expect": { "import": false } },
    { "name": "github copilot host -> SKIP", "baseUrl": "https://api.githubcopilot.com", "key": "gho_static0001", "expect": { "import": false } },
    { "name": "JWT oauth token -> SKIP even on a sanctioned host", "baseUrl": "https://api.kimi.com/coding/v1", "key": "eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ9.payload.signature", "expect": { "import": false } },
    { "name": "google refresh-token shape -> SKIP", "baseUrl": "https://api.deepseek.com/v1", "key": "1//0enRefreshTokenShape", "expect": { "import": false } },
    { "name": "empty key -> SKIP", "baseUrl": "https://api.deepseek.com/v1", "key": "", "expect": { "import": false } }
  ]
}
